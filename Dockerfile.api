FROM python:3.10-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends docker.io docker-cli curl ca-certificates && apt-get clean && rm -rf /var/lib/apt/lists/*

COPY mission-control/api/requirements.txt .

RUN pip install --no-cache-dir -r requirements.txt

COPY mission-control/api /app/api

CMD ["uvicorn", "api.main:app", "--host", "0.0.0.0", "--port", "8000"]