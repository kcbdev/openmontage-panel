# Database
DB_URL=postgresql+psycopg://postgres:dev@postgres/mission_control

# Redis (required for rate limiting + WebSocket pub/sub)
REDIS_URL=redis://redis:6379/0

# JWT auth (change in production!)
# Generate a secure key: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=dev-secret-key-change-in-production
JWT_EXPIRE_MINUTES=480

# Credential encryption
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=mission-control-assets

# Engine
ENGINE_IMAGE=openmontage-engine:mc-v0
PROJECTS_DIR=/data/projects

# Logging (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO

# Engine mode (stub | real)
# "stub" uses a sidecar that simulates all pipeline stages with fake data.
# "real" launches the actual engine container with AI tool execution.
# Build the engine image first: docker build -t openmontage-engine:mc-v0 engine/
# Then run with: ENGINE_MODE=real docker compose --profile real up
ENGINE_MODE=stub
STUB_SPEED=fast
